  "keyFeatures": [
    "RadixAttention for efficient prefix caching",
    "Zero-overhead CPU scheduler for continuous batching",
    "Prefill-decode disaggregation for optimized resource usage",
    "Multi-dimensional parallelism (tensor/pipeline/expert/data)",
    "Structured outputs with compressed FSM",
    "Multi-LoRA batching for serving multiple adapters",
    "Speculative decoding for faster inference",
    "Quantization support (FP4/FP8/INT4/AWQ/GPTQ)",
    "OpenAI-compatible API endpoints",
    "Support for 100+ LLM and multimodal models",
    "Hardware support (NVIDIA/AMD/Intel/Google TPU)",
    "Native RL and post-training integrations",
    "Frontend language for constrained generation",
    "HiCache for long-context optimization"
  ],
  "publicApiSurface": [
    "sglang.Engine - Offline inference engine",
    "sglang.Runtime - Runtime endpoint for frontend",
    "sglang.ServerArgs - Server configuration",
